- content_for :title, "Dashboard"

= section do
  = stack({ narrow: true }) do
    = card do
      = prose do
        = h2({ id: "add" }, "Add something")
      = form_with(url: media_path, method: :post) do |f|
        = stack({ gap: 3 }) do
          = f.klods_field :url, label: "URL", type: :text, placeholder: "https://www.youtube.com/watch?v=...", required: true, inputmode: "url", autocomplete: "url"
          = f.klods_submit "Add to inbox"

= section do
  = stack({ gap: 4 }) do
    = prose do
      = h1({ id: "inbox" }, "Inbox")
    - if @inbox_items.empty?
      = prose do
        = p("Nothing in your inbox yet. Add something!")
    - else
      = stack({ gap: 4 }) do
        - @inbox_items.each do |item|
          = card do
            = cluster({ gap: 4 }) do
              - if item.media.thumbnail_url.present?
                %img{ src: item.media.thumbnail_url, alt: "", style: "width: 120px; border-radius: 4px; flex-shrink: 0;" }
              = stack({ gap: 1 }) do
                = card_title(a({href: share_path(item.share)}, item.media.title || item.media.url))
                = muted(item.media.author.presence || item.media.site_name.presence || URI.parse(item.media.normalized_url).host)
                = cluster({ gap: 2 }) do
                  - if item.status != "watched"
                    = button({ variant: "primary", href: share_path(item.share), size: "sm" }, "Watch")
                    = form_with(url: list_list_item_path(current_user.inbox, item), method: :patch, style: "display: inline;") do |f|
                      = f.hidden_field :status, value: "watched"
                      = f.button("Mark watched", class: "klods-button klods-button--sm")
                  - else
                    = badge({ variant: "success" }, "Watched")
