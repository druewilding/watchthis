!!! 5
%html{ lang: "en", "data-theme": "dark" }
  %head
    %title= content_for(:title) || "WatchThis"
    %meta{ charset: "UTF-8" }
    %meta{ name: "viewport", content: "width=device-width, initial-scale=1.0" }
    = csrf_meta_tags
    = csp_meta_tag
    %link{ rel: "icon", href: "/icon.png", type: "image/png" }
    %link{ rel: "icon", href: "/icon.svg", type: "image/svg+xml" }
    %link{ rel: "stylesheet", href: "https://unpkg.com/klods-css/dist/klods.min.css" }
    = javascript_importmap_tags
  %body
    = page({ sidebar: user_signed_in? }) do
      = header do
        - if user_signed_in?
          = sidebar_toggle
        = strong("WatchThis")
        = push
        = nav_list do
          - if user_signed_in?
            = nav_link({ href: "/", active: request.path == "/" }, "Home")
            = nav_link({ href: destroy_user_session_path, "data-turbo-method": "delete" }, "Sign out")
          - else
            = nav_link({ href: new_user_session_path, active: request.path == new_user_session_path }, "Sign in")
            = nav_link({ href: new_user_registration_path, active: request.path == new_user_registration_path }, "Sign up")
      - if user_signed_in?
        = sidebar do
          - if content_for?(:sidebar)
            = Klods::Core.raw(content_for(:sidebar))
          - else
            = toc do
              = toc_item(toc_link({ href: "/" }, "Home"))
      = content do
        - if notice.present?
          = Klods::Core.raw(tag.p(notice, class: "klods-notice"))
        - if alert.present?
          = Klods::Core.raw(tag.p(alert, class: "klods-alert"))
        = Klods::Core.raw(yield)
      = footer("WatchThis")
