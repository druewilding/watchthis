!!! 5
%html{ lang: "en", "data-theme": "dark" }
  %head
    %title= content_for(:title) || "WatchThis"
    %meta{ charset: "UTF-8" }
    %meta{ name: "viewport", content: "width=device-width, initial-scale=1.0" }
    = csrf_meta_tags
    = csp_meta_tag
    %link{ rel: "icon", href: "/icon.png", type: "image/png" }
    %link{ rel: "icon", href: "/icon.svg", type: "image/svg+xml" }
    %link{ rel: "stylesheet", href: "https://unpkg.com/klods-css/dist/klods.min.css" }
    = javascript_importmap_tags
    = yield(:head)
  %body
    = page({ sidebar: user_signed_in? }) do
      = header do
        - if user_signed_in?
          = sidebar_toggle
        = link({ href: root_path, plain: true }, strong("WatchThis"))
        = push
        = nav_list do
          - if user_signed_in?
            = nav_link({ href: dashboard_path, active: request.path == dashboard_path }, "Inbox")
            = nav_link({ href: friendships_path, active: request.path.start_with?(friendships_path) }, "Friends")
            = nav_link({ href: destroy_user_session_path, "data-turbo-method": "delete" }, "Sign out")
          - else
            = nav_link({ href: new_user_session_path, active: request.path == new_user_session_path }, "Sign in")
            = nav_link({ href: new_user_registration_path, active: request.path == new_user_registration_path }, "Sign up")
      - if user_signed_in?
        = sidebar do
          - if content_for?(:sidebar)
            = content_for(:sidebar)
          - else
            = toc do
              = toc_item(toc_link({ href: dashboard_path }, "Inbox"))
      = content do
        = stack({ gap: 6 }) do
          - if notice.present?
            %div{ role: "alert", class: "klods-alert klods-alert--success" }= notice
          - if alert.present?
            %div{ role: "alert", class: "klods-alert klods-alert--danger" }= alert
          = yield
      = footer("WatchThis")
