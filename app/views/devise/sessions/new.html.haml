- content_for :title, "Sign in — WatchThis"

= stack({ gap: 6 }) do
  = prose do
    = h1("Sign in")
    = p do
      = "New to WatchThis? "
      = link_to("Create an account", new_user_registration_path)

  = form_with(model: resource, as: resource_name, url: session_path(resource_name)) do |f|
    = stack({ gap: 4 }) do
      %div
        = f.label :email, "Email"
        = f.email_field :email, autofocus: true, autocomplete: "email"
      %div
        = f.label :password, "Password"
        = f.password_field :password, autocomplete: "current-password"
      = cluster({ gap: 3 }) do
        = f.submit "Sign in", class: "klods-button klods-button--primary"
        = link_to "Forgot your password?", new_user_password_path
