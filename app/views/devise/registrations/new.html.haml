- content_for :title, "Sign up — WatchThis"

= stack({ gap: 6 }) do
  = prose do
    = h1("Create your account")
    = p do
      = "Already have an account? "
      = link_to("Sign in", new_user_session_path)

  = form_with(model: resource, as: resource_name, url: registration_path(resource_name)) do |f|
    = stack({ gap: 4 }) do
      - if resource.errors.any?
        %ul
          - resource.errors.full_messages.each do |msg|
            %li= msg

      %div
        = f.label :email, "Email"
        = f.email_field :email, autofocus: true, autocomplete: "email"
      %div
        = f.label :password, "Password (6 characters minimum)"
        = f.password_field :password, autocomplete: "new-password"
      %div
        = f.label :password_confirmation, "Confirm password"
        = f.password_field :password_confirmation, autocomplete: "new-password"
      = f.submit "Sign up", class: "klods-button klods-button--primary"
