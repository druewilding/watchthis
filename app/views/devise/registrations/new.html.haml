- content_for :title, "Sign up — WatchThis"

= stack({ narrow: true }) do
  = card do
    = prose do
      = h1("Create your account")
      = p do
        = "Already have an account? "
        = link_to("Sign in", new_user_session_path)

    = form_with(model: resource, as: resource_name, url: registration_path(resource_name)) do |f|
      = stack({ gap: 4 }) do
        = f.klods_field :display_name, label: "Name", autofocus: true, autocomplete: "name"
        = f.klods_field :email, required: true, type: :email, autocomplete: "email"
        = f.klods_field :password, required: true, label: "Password (6 characters minimum)", type: :password, autocomplete: "new-password"
        = f.klods_field :password_confirmation, required: true, label: "Confirm password", type: :password, autocomplete: "new-password"
        = f.klods_submit "Sign up"
